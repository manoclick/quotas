rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: zones
    // Fields: name (string)
    //
    // Collection: circles
    // Fields: name (string), zoneId (string)
    //
    // Collection: cells
    // Fields: name (string), circleId (string)
    //
    // Collection: functions
    // Fields: name (string)
    //
    // Collection: teachers
    // Fields: name (required), cellId (required), defaultAmount (required), zoneId, circleId, functionId, cardNumber, email, contact, createdAt
    //
    // Collection: payments
    // Fields: teacherId, month, year, amount, status, paidAt, recordedBy
    //
    // Collection: users
    // Fields: email, name, role (admin, gestor, gestor_celula, professor)
    //
    // Collection: system_configs
    // Fields: activeMonths (array), year (number)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null && exists(/databases/$(database)/documents/active_sessions/$(request.auth.uid));
    }

    function getSession() {
      return get(/databases/$(database)/documents/active_sessions/$(request.auth.uid)).data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(getSession().username)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isGestor() {
      return isAuthenticated() && (getUserData().role == 'gestor' || getUserData().role == 'admin');
    }

    function isGestorCelula() {
      return isAuthenticated() && (getUserData().role == 'gestor_celula' || getUserData().role == 'gestor' || getUserData().role == 'admin');
    }

    function isProfessor() {
      return isAuthenticated();
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidZone(data) {
      return hasOnlyAllowedFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidCircle(data) {
      return hasOnlyAllowedFields(['name', 'zoneId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.zoneId is string;
    }

    function isValidCell(data) {
      return hasOnlyAllowedFields(['name', 'circleId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.circleId is string;
    }

    function isValidFunction(data) {
      return hasOnlyAllowedFields(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidTeacher(data) {
      return hasRequiredFields(['name', 'cellId', 'defaultAmount']) &&
             data.name is string && data.name.size() > 0 &&
             data.cellId is string &&
             data.defaultAmount is number && data.defaultAmount >= 0 &&
             (data.email == null || data.email is string);
    }

    function isValidPayment(data) {
      return hasRequiredFields(['teacherId', 'month', 'year', 'amount', 'status']) &&
             data.month >= 1 && data.month <= 12 &&
             data.year >= 2000 &&
             data.amount >= 0 &&
             data.status in ['paid', 'pending'];
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role']) &&
             data.role in ['admin', 'gestor', 'gestor_celula', 'professor'];
    }

    function isValidConfig(data, id) {
      return (id == 'permissions' && data.keys().hasAny(['admin', 'gestor', 'gestor_celula', 'professor'])) ||
             (id != 'permissions' && hasRequiredFields(['activeMonths', 'year']) &&
              data.activeMonths is list &&
              data.year is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if (request.auth != null && isAdmin()) || (userId == 'admin' && !exists(/databases/$(database)/documents/users/admin));
      allow update: if isAdmin() || (isAuthenticated() && getSession().username == userId);
      allow delete: if isAdmin();
    }

    match /active_sessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == sessionId;
      allow write: if request.auth != null && request.auth.uid == sessionId;
    }

    match /zones/{zoneId} {
      allow read: if isProfessor();
      allow create, update: if isGestor() && isValidZone(request.resource.data);
      allow delete: if isAdmin();
    }

    match /circles/{circleId} {
      allow read: if isProfessor();
      allow create, update: if isGestor() && isValidCircle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /cells/{cellId} {
      allow read: if isProfessor();
      allow create, update: if isGestor() && isValidCell(request.resource.data);
      allow delete: if isAdmin();
    }

    match /functions/{functionId} {
      allow read: if isProfessor();
      allow create, update: if isGestor() && isValidFunction(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isProfessor();
      allow create, update: if isGestorCelula() && isValidTeacher(request.resource.data);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isProfessor();
      allow create, update: if isGestorCelula() && isValidPayment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /system_configs/{configId} {
      allow read: if isProfessor();
      allow create, update: if isGestor() && isValidConfig(request.resource.data, configId);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
